{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "article-for-agents",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  // 正式域名（zone: echohx.com）；workers.dev 旧地址继续可用
  // 保留 workers.dev 旧地址（已分发的链接/海报/订阅 feed 依赖它）
  "workers_dev": true,
  "routes": [
    { "pattern": "echohx.com", "custom_domain": true },
    { "pattern": "www.echohx.com", "custom_domain": true }
  ],
  // 把仓库里的 SKILL.md 打包进 worker，经 GET /skill.md 分发
  "rules": [{ "type": "Text", "globs": ["**/*.md"] }],
  "kv_namespaces": [
    {
      "binding": "A4A_KV",
      // 自部署时运行: npx wrangler kv namespace create A4A_KV，把返回的 id 填到这里
      "id": "58fc9aace2104f6e9d60cfea6f83ef48"
    }
  ],
  "r2_buckets": [
    {
      "binding": "A4A_R2",
      // 图片托管。自部署时运行: npx wrangler r2 bucket create a4a-images
      // （需要在 Cloudflare 控制台启用 R2，免费额度 10GB。不想用图片托管可删除本段，功能自动降级）
      "bucket_name": "a4a-images"
    }
  ],
  "vars": {
    // 允许任何人调用 POST /v1/keys 自助注册 token；
    // 公共实例如果担心滥用可设为 "false"，改为手动发 token
    "OPEN_REGISTRATION": "true",
    // 单篇文章正文大小上限（字节）
    "MAX_CONTENT_BYTES": "1048576"
  }
}
